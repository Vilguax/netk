FROM node:22-alpine AS base
WORKDIR /app

FROM base AS deps
COPY package.json package-lock.json ./
COPY apps ./apps
COPY packages ./packages
COPY tsconfig.json tsconfig.base.json turbo.json ./
RUN npm install
RUN npm run db:generate -w @netk/database

FROM deps AS builder
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_OPTIONS=--max-old-space-size=1536
ARG AUTH_URL
ARG NEXT_PUBLIC_GATEWAY_URL
ARG NEXT_PUBLIC_FLIPPER_URL
ARG NEXT_PUBLIC_RATTING_URL
ARG NEXT_PUBLIC_ROCK_RADAR_URL
ARG NEXT_PUBLIC_APPRAISAL_URL
ARG NEXT_PUBLIC_FLEET_URL
ARG NEXT_PUBLIC_MARKET_URL
ARG NEXT_PUBLIC_PI_URL
ENV AUTH_URL=$AUTH_URL
ENV NEXT_PUBLIC_GATEWAY_URL=$NEXT_PUBLIC_GATEWAY_URL
ENV NEXT_PUBLIC_FLIPPER_URL=$NEXT_PUBLIC_FLIPPER_URL
ENV NEXT_PUBLIC_RATTING_URL=$NEXT_PUBLIC_RATTING_URL
ENV NEXT_PUBLIC_ROCK_RADAR_URL=$NEXT_PUBLIC_ROCK_RADAR_URL
ENV NEXT_PUBLIC_APPRAISAL_URL=$NEXT_PUBLIC_APPRAISAL_URL
ENV NEXT_PUBLIC_FLEET_URL=$NEXT_PUBLIC_FLEET_URL
ENV NEXT_PUBLIC_MARKET_URL=$NEXT_PUBLIC_MARKET_URL
ENV NEXT_PUBLIC_PI_URL=$NEXT_PUBLIC_PI_URL
ARG APP_DIR
RUN test -n "$APP_DIR"
RUN sh -c "cd \"$APP_DIR\" && npx next build"

FROM base AS runner
ENV NODE_ENV=production
COPY --from=builder /app /app
RUN npm prune --omit=dev
ARG APP_DIR
ARG APP_PORT
ENV APP_DIR=$APP_DIR
ENV PORT=$APP_PORT
EXPOSE 3000
CMD ["sh", "-c", "cd \"$APP_DIR\" && npx next start -p \"$PORT\""]
